# DeepSeek API
# Optional. Users can enter this in the web UI instead.
# Backend env value is only used as a fallback when the frontend key is empty.
DEEPSEEK_API_KEY=

# Image2 API
# Optional. Users can enter this in the web UI instead.
# Backend env value is only used as a fallback when the frontend key is empty.
IMAGE_API_KEY=
IMAGE_API_BASE_URL=https://api.duojie.games/v1

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/manga_novel

# Server
HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_UPLOAD_BYTES=10485760
# Optional. If set, frontend must set matching VITE_API_TOKEN.
API_TOKEN=
