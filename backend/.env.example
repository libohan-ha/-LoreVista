# DeepSeek API (Required)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Image2 API (Required)
IMAGE_API_KEY=your_image_api_key_here
IMAGE_API_BASE_URL=https://api.duojie.games/v1

# Database
# SQLite is used by default: backend/data/lorevista.db
# Optional: use another SQLite file path.
# SQLITE_DB_PATH=data/lorevista.db

# Server
HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_UPLOAD_BYTES=10485760
# Optional. If set, frontend must set matching VITE_API_TOKEN.
API_TOKEN=
