# DeepSeek API (Required)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Image2 API (Required)
IMAGE_API_KEY=your_image_api_key_here
IMAGE_API_BASE_URL=https://api.duojie.games/v1

# Database (default = SQLite zero-config)
# Leave empty or comment out to use SQLite (recommended for beginners)
# Uncomment to use PostgreSQL:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/manga_novel

# Server
HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_UPLOAD_BYTES=10485760
# Optional. If set, frontend must set matching VITE_API_TOKEN.
API_TOKEN=
